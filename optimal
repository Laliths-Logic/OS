#include <stdio.h>

int main() {

    int n, frames;

    printf("Enter number of pages in reference string: \n");
    scanf("%d", &n);

    int ref[n];

    printf("Enter the reference string: \n");

    for(int i = 0; i < n; i++) {
        scanf("%d", &ref[i]);
    }

    printf("Enter number of frames: \n");
    scanf("%d", &frames);

    int frame[frames];

    for(int i = 0; i < frames; i++) {
        frame[i] = -1;
    }

    int faults = 0;
    int hits = 0;

    for(int i = 0; i < n; i++) {

        int found = 0;

        for(int j = 0; j < frames; j++) {
            if(frame[j] == ref[i]) {
                hits++;
                found = 1;
                break;
            }
        }

        if(!found) {

            int index = -1;

            for(int j = 0; j < frames; j++) {
                if(frame[j] == -1) {
                    index = j;
                    break;
                }
            }

            if(index == -1) {
                int farthest = -1;

                for(int j = 0; j < frames; j++) {

                    int k;

                    for(k = i + 1; k < n; k++) {
                        if(frame[j] == ref[k]) {
                            if(k > farthest) {
                                farthest = k;
                                index = j;
                            }
                            break;
                        }
                    }

                    if(k == n) {
                        index = j;
                        break;
                    }
                }
            }

            frame[index] = ref[i];
            faults++;
        }

    }

    printf("\nTotal Page Faults: %d\n", faults);
    printf("Total Page Hits: %d\n", hits);

    return 0;
}
